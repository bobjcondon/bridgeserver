{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "SvelteKit (Node)",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "bun",
			"runtimeArgs": ["--bun", "run", "dev"],
			"cwd": "${workspaceFolder}",
			"env": {
				"NODE_OPTIONS": "--inspect"
			},
			"skipFiles": ["<node_internals>/**"],
			"smartStep": true,
			"sourceMaps": true,
			"outFiles": ["${workspaceFolder}/.svelte-kit/**/*.js"]
		},
		{
			"name": "Chrome — SvelteKit client",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}/src",
			"sourceMapPathOverrides": {
				"/@fs/*": "/*",
				"/src/*": "${workspaceFolder}/src/*"
			}
		}
	],
	"compounds": [
		{
			"name": "SvelteKit full-stack",
			"configurations": ["SvelteKit (Node)", "Chrome — SvelteKit client"]
		}
	]
}
